---
import Base from '@/layouts/Base.astro';
---
<Base title="Home">
  <section class="hero">
    <div class="container">
      <div class="hero-badge animate-fade-up">
        <span class="pill pill-pink">UK-focused</span>
        <span class="pill pill-blue">Community-sourced</span>
      </div>
      <h1 class="hero-title animate-fade-up" style="animation-delay: 80ms">
        What We Know
      </h1>
      <p class="hero-subtitle animate-fade-up" style="animation-delay: 160ms">
        Clear, sourced answers to the questions trans people actually ask. Compiled from clinical guidelines, community experience, and public data. Reviewed by real people. Free forever.
      </p>
      <div class="hero-cta animate-fade-up" style="animation-delay: 240ms">
        <a href="/topics" class="btn btn-primary">Browse topics</a>
        <a href="/about" class="btn btn-secondary">How this works</a>
      </div>
    </div>
  </section>

  <section class="topics-preview">
    <div class="container-wide">
      <h2 class="section-title animate-fade-up">Latest topics</h2>
      <div class="topic-grid stagger">

        <a href="/topics/nhs-waiting-times" class="card topic-card">
          <div class="topic-card-tags">
            <span class="pill pill-blue">UK</span>
            <span class="pill pill-blue">NHS</span>
          </div>
          <h3>NHS waiting times by clinic</h3>
          <p>Current waiting times at every NHS gender identity clinic in England and Scotland, with data sources.</p>
          <div class="topic-card-meta">
            <span class="confidence confidence-strong">
              <span class="confidence-dot"></span>
              Strong consensus
            </span>
          </div>
        </a>

        <a href="/topics/name-change-england-wales" class="card topic-card">
          <div class="topic-card-tags">
            <span class="pill pill-blue">UK</span>
            <span class="pill pill-pink">Legal</span>
          </div>
          <h3>Changing your name (England & Wales)</h3>
          <p>Deed poll vs statutory declaration, where to send it, what it costs, and what to update.</p>
          <div class="topic-card-meta">
            <span class="confidence confidence-strong">
              <span class="confidence-dot"></span>
              Strong consensus
            </span>
          </div>
        </a>

        <a href="/topics/blood-work-basics" class="card topic-card">
          <div class="topic-card-tags">
            <span class="pill pill-pink">Health</span>
          </div>
          <h3>Blood work basics</h3>
          <p>What to test, target ranges, when to test, and how to read your results.</p>
          <div class="topic-card-meta">
            <span class="confidence confidence-strong">
              <span class="confidence-dot"></span>
              Strong consensus
            </span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <section class="how-it-works">
    <div class="container">
      <hr class="divider" />
      <h2 class="section-title">How this works</h2>
      <div class="how-grid stagger">
        <div class="how-item">
          <div class="how-number">1</div>
          <h3>We gather</h3>
          <p>We pull from clinical guidelines, published research, community sites, and public forums. Every source is logged.</p>
        </div>
        <div class="how-item">
          <div class="how-number">2</div>
          <h3>We synthesise</h3>
          <p>We identify what the evidence says, what the community says, and where people disagree. Nothing is hidden.</p>
        </div>
        <div class="how-item">
          <div class="how-number">3</div>
          <h3>We review</h3>
          <p>Every page is reviewed by a real person before it goes live. When things change, we update and say so.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="callout callout-blue">
        <p><strong>This project is just getting started.</strong> We're building this in public. If you want to help, spot an error, or suggest a topic, <a href="/contact">get in touch</a>.</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: var(--space-4xl) 0 var(--space-3xl);
    text-align: center;
  }

  .hero-badge {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 4rem);
    background: linear-gradient(135deg, var(--blue) 0%, var(--pink) 50%, var(--blue) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 8s ease-in-out infinite;
    margin-bottom: var(--space-lg);
  }

  @keyframes shimmer {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto var(--space-2xl);
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-xl);
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn:active {
    transform: translateY(0);
  }

  .btn-primary {
    background: var(--text);
    color: var(--white);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }

  .btn-primary:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.16);
    color: var(--white);
  }

  .btn-secondary {
    background: var(--white);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--pink-muted);
  }

  /* Topics preview */
  .topics-preview {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .section-title {
    margin-bottom: var(--space-2xl);
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .topic-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .topic-card h3 {
    margin: 0;
    font-size: 1.15rem;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .topic-card:hover h3 {
    color: #1a7ba3;
  }

  .topic-card p {
    font-size: 0.9rem;
    margin: 0;
    flex: 1;
  }

  .topic-card-tags {
    display: flex;
    gap: var(--space-xs);
  }

  .topic-card-meta {
    margin-top: var(--space-sm);
  }

  /* How it works */
  .how-it-works {
    padding: var(--space-xl) 0 var(--space-3xl);
  }

  .how-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-xl);
  }

  .how-item h3 {
    margin: var(--space-sm) 0;
    font-size: 1.1rem;
  }

  .how-item p {
    font-size: 0.9rem;
  }

  .how-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--blue-soft), var(--pink-soft));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--text);
  }

  /* CTA */
  .cta-section {
    padding-bottom: var(--space-3xl);
  }
</style>
